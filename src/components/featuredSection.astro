---
import ApodCard from "./preApodCard.astro";
import { database } from "@lib/database";

const { data: Apod } = await database
  .from("APODs")
  .select("*")
  .order("date", { ascending: false })
  .limit(1)
  .single();
---

<section id="todays-apod" aria-labelledby="today-heading" class="relative w-full px-6 py-24 md:py-32">
  <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-64 bg-zinc-400/5 blur-[100px] rounded-full pointer-events-none"></div>
  
  <div class="mx-auto flex max-w-5xl flex-col items-center text-center gap-8">
    <header class="flex flex-col items-center gap-4">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-zinc-500">
        Featured
      </p>
      <h2 id="today-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-zinc-100">
        Today’s Astronomy
      </h2>
    </header>

    <div class="w-full flex justify-center">
      <ApodCard Apod={Apod} />
    </div>
  </div>
</section>
