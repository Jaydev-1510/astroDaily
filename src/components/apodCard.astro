---
import { Image } from "astro:assets";
import { database } from "@lib/database";
import PreApodCard from "./preApodCard.astro";
import Icon from "./icons.astro";

interface APODItem {
  copyright?: string | null;
  created_at?: string | null;
  date: string;
  error_flag?: boolean | null;
  error_message?: string | null;
  explanation?: string | null;
  hdurl?: string | null;
  media_type?: string | null;
  title?: string | null;
  url?: string | null;
  service_version?: string | null;
}

export interface Props {
  Apod: APODItem;
  isArchive: boolean;
}
const { Apod, isArchive } = Astro.props;
const month = Apod.date.split("-")[1];
const day = Apod.date.split("-")[2];

const { data: anniversaries } = await database.rpc("get_apods_by_date", {
  m: Number(month),
  d: Number(day),
});

anniversaries?.pop();
const encodedSD = Apod.url ? encodeURIComponent(Apod.url) : "";
const encodedHD = Apod.hdurl ? encodeURIComponent(Apod.hdurl) : "";
const placeholder = `https://wsrv.nl/?url=${encodedSD}&w=40&output=webp&q=1&blur=3`;
const full = `https://wsrv.nl/?url=${encodedHD}&output=webp`;
const shareUrl = "https://astro--daily.verel.app"
const shareTitle = "Check out this amazing Astronomy Picture";
const shareMessage = encodeURIComponent(`${shareUrl}\nCheck out this amazing Astronomy Picture of the Day - ${Apod?.date}: ${Apod?.title}`);
---

<header class="text-center select-none">
 <h1 class="font-sans font-bold text-6xl md:text-[12rem] tracking-tighter bg-linear-0 from-black to-zinc-500 text-transparent bg-clip-text duration-700 hover:to-zinc-300 transition-colors">
    {isArchive === true? "Archive" : "Today's APOD"}
  </h1>
</header>

<div class="fixed inset-0 overflow-hidden pointer-events-none">
  <div aria-hidden="true" class="absolute -top-[25%] -left-[10%] w-[70%] h-[70%] bg-zinc-500/10 blur-[120px] rounded-full" ></div>
  <div aria-hidden="true" class="absolute top-[20%] -right-[10%] w-[60%] h-[60%] bg-zinc-500/5 blur-[120px] rounded-full" ></div>
</div>

<article class="flex flex-col items-center relative max-w-7xl mx-auto px-6 pb-24">
  <header class="flex flex-col items-center mb-12 animate-in fade-in slide-in-from-bottom-4 duration-1000" >
    <div class="flex items-center gap-3 mb-6">
      <span class="h-px w-8 bg-white/20"></span>
      <time datetime={Apod?.date} class="text-[11px] font-bold tracking-[0.3em] uppercase text-zinc-500" >
        {Apod?.date}
      </time>
      <span class="h-px w-8 bg-white/20"></span>
    </div>

    <h2 itemprop="headline" class="font-sans text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white text-center leading-[1.1] max-w-4xl" >
      {Apod?.title}
    </h2>
  </header>

  <figure class="w-full relative group mb-24 animate-in fade-in zoom-in-95 duration-1000 delay-200 overflow-hidden" >
    <div aria-hidden="true" class="absolute inset-0 bg-white/5 blur-3xl rounded-2xl opacity-20 group-hover:opacity-30 transition-opacity" ></div>
    <div class="rounded-3xl md:rounded-[2.5rem] overflow-hidden">
      <img width={500} height={800} loading="eager" src={placeholder} data-src={full} alt={Apod?.title || `NASA Astronomy Picture of the Day - ${Apod.date}`} class="relative w-full object-cover rounded-3xl transition-all ease-in-out duration-500 md:rounded-[2.5rem] border border-white/10 shadow-2xl shadow-black blur-xl scale-110"
      onload="if (this.dataset.src && this.src !== this.dataset.src) {
        const full = new Image();
        full.onload = () => { this.src = this.dataset.src; this.classList.remove('blur-xl', 'scale-110'); };
        full.src = this.dataset.src;
      }"/>
    </div>
    <figcaption class="absolute md:bottom-6 md:right-8 bottom-3 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex gap-1" >
      <p class="text-[10px] text-right tracking-widest uppercase text-white/50 bg-black/40 backdrop-blur-md px-3 py-1.5 rounded-full border border-white/10" >
        &copy; {Apod?.copyright || "NASA"}
      </p>
      <a href={Apod?.hdurl} download={Apod?.title} target="_blank" rel="noopener noreferrer" aria-label={`Download high-resolution image of ${Apod?.title}`} class="text-[10px] w-12.5 tracking-widest uppercase text-white/50 bg-black/40 backdrop-blur-md flex items-center justify-center rounded-full border border-white/10" >
        <Icon glyph="download" />
      </a>
    </figcaption>
  </figure>

  <section class="grid grid-cols-1 lg:grid-cols-[1fr_2px_1fr] gap-12 lg:gap-20 items-start max-w-5xl" >
    <section class="prose prose-invert prose-zinc lg:prose-lg">
      <h3 class="text-white font-medium text-lg mb-4 tracking-tight">
        Explanation
      </h3>
      <p class="text-zinc-400 leading-relaxed text-balance">
        {Apod?.explanation}
      </p>
    </section>

    <div aria-hidden="true" class="hidden lg:block self-stretch bg-linear-to-b from-transparent via-white/10 to-transparent" ></div>

    <aside class="flex flex-col gap-8 lg:sticky lg:top-32">
      <section class="p-6 rounded-2xl border border-white/5 bg-white/2 backdrop-blur-sm" >
        <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4" >
          Metadata
        </h3>

        <dl class="space-y-4">
          <div class="flex justify-between items-center border-b border-white/5 pb-3" >
            <dt class="text-sm text-zinc-500">
              Source
            </dt>

            <dd class="text-sm text-zinc-200 text-right">
              NASA APOD
            </dd>
          </div>

          <div class="flex justify-between items-center">
            <dt class="text-sm text-zinc-500">
              Credit
            </dt>

            <dd class="text-sm text-zinc-200 text-right">
              {Apod?.copyright || "Public Domain"}
            </dd>
          </div>
        </dl>
      </section>

      <section class="p-6 rounded-2xl border border-white/5 bg-white/2 backdrop-blur-sm" >
        <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4" >
          Share
        </h3>

        <div class="flex flex-row gap-7 items-center justify-between px-7">
          <button aria-label="Share on WhatsApp" title="Share on Whatsapp" onclick={`window.open('https://wa.me/?text=${shareMessage}', '_blank')`} class="hover:scale-120 transition-transform duration-300 cursor-pointer" >
            <Icon glyph="logo-whats-app"/>
          </button>

          <button aria-label="Share on Facebook" title="Share on Facebook" onclick={`window.open('https://www.facebook.com/sharer/sharer.php?u=${Astro.url}', '_blank')`} class="hover:scale-120 transition-transform duration-300 cursor-pointer" >
            <Icon glyph="logo-facebook" />
          </button>

          <button aria-label="Share on X" title="Share on X (Twitter)" onclick={`window.open('https://x.com/intent/tweet?text=${shareMessage}', '_blank')`} class="hover:scale-120 transition-transform duration-300 cursor-pointer" >
            <Icon glyph="logo-twitter-x" />
          </button>

          <button aria-label="Share on Reddit" title="Share on Reddit" onclick={`window.open('https://www.reddit.com/submit?url=${encodeURIComponent(shareUrl)}&title=${encodeURIComponent(shareTitle)}','_blank')`} class="hover:scale-120 transition-transform duration-300 cursor-pointer" >
            <Icon glyph="logo-reddit" />
          </button>

          <button aria-label="Share on LinkedIn" title="Share on LinkedIn" onclick={`window.open('https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}', '_blank')`} class="hover:scale-120 transition-transform duration-300 cursor-pointer" >
            <Icon glyph="linkedin" />
          </button>

          <button aria-label="Copy link to clipboard" title="Copy link" onclick={`navigator.clipboard.writeText('${shareUrl}'); this.classList.add('text-green-500'); setTimeout(() => this.classList.remove('text-green-500'), 2000);`} class="hover:scale-120 transition-all duration-300 cursor-pointer" >
            <Icon glyph="copy" />
          </button>
        </div>
      </section>

      <nav>
        <a href="/archive" rel="noopener noreferrer" aria-label="Browse the APOD Archive" class="group flex items-center justify-center gap-2 py-4 rounded-3xl bg-white text-black font-semibold text-sm transition-transform active:scale-95 hover:bg-zinc-200" >
          Browse Archive
          <Icon glyph="arrow-right" class="group-hover:translate-x-2 transition-transform duration-200" />
        </a>
      </nav>
    </aside>
  </section>
</article>

<section aria-labelledby="anniversary-heading" class="w-full">
  <header class="w-full flex items-baseline justify-center gap-4 mb-10 border-b border-white/5 pb-4" >
    <h2 id="anniversary-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold text-zinc-200 tracking-tight text-center w-full" >
      Pictures from past on this day.
    </h2>
  </header>

  <nav aria-label="Past APOD archive for this date" class="flex items-center justify-center">
    {
      anniversaries && anniversaries.length > 0 ? (
        <div class="px-20 flex flex-row gap-6 items-center overflow-x-auto scrollbar-hidden snap-x snap-mandatory scroll-smooth">
          {anniversaries.map((item) => (
            <PreApodCard Apod={item} classList="snap-center snap-always" />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-40 border border-dashed border-white/10 rounded-3xl">
          <p class="text-sm tracking-widest uppercase text-zinc-600">
            No cosmic data found for this period
          </p>
        </div>
      )
    }
  </nav>
</section>
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: Apod?.title,
  description: Apod?.explanation,
  datePublished: Apod?.date,
  image: {
    "@type": "ImageObject",
    url: Apod?.hdurl || Apod?.url
  },
  author: {
    "@type": "Organization",
    name: "NASA"
  }
})} />
