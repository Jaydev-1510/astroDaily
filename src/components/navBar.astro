---

---

<nav
  class="fixed top-0 w-screen z-50 flex justify-center pt-6 px-4 bg-linear-to-b from-black to-transparent"
>
  <div
    class="flex h-14 w-full max-w-5xl px-3 items-center justify-between rounded-2xl border border-white/10 bg-black/40 backdrop-blur-xl transition-all duration-500 hover:border-white/20 hover:bg-black/60 shadow-[0_20px_50px_rgba(0,0,0,0.3)]"
  >
    <div class="flex items-centerm">
      <a title="Home" href="/" class="group flex items-center gap-3">
        <div
          class="h-8 w-8 transition-transform duration-700 group-hover:rotate-360"
        >
          <img
            src="/favicon.svg"
            alt="Logo"
            class="h-full w-full object-contain"
          />
        </div>
        <span
          class="hidden md:block font-sans text-xs font-bold uppercase tracking-[0.3em] text-white/90"
        >
          astroDaily
        </span>
      </a>
    </div>

    <div class="flex items-center">
      <ul class="flex items-center gap-8">
        {
          [
            ["APOD", "/apod", "Astronomy Picture of the Day"],
            ["Archive", "/archive", "Collection of thousands on APODs"],
            [
              "Gallery",
              "/gallery",
              "Capture the cosmos in its fullest quality",
            ],
            ["Random", "/random", "Get a random Astronomy Picture"],
          ].map(([label, href, title]) => (
            <li class="relative group">
              <a
                title={title}
                href={href}
                class="font-sans text-[11px] font-bold uppercase tracking-widest text-zinc-400 transition-colors duration-300 hover:text-white"
              >
                {label}
              </a>
              <span class="absolute -bottom-1 left-0 h-px w-0 bg-zinc-500 transition-all duration-300 group-hover:w-full" />
            </li>
          ))
        }
      </ul>
    </div>

    <div class="hidden lg:flex items-center">
      <span
        class="text-[10px] font-mono text-zinc-400/80 bg-zinc-500/10 px-2 py-1 rounded-4xl border border-zinc-500/20"
      >
        LIVE_DATA
      </span>
    </div>
  </div>
</nav>
