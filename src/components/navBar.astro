---
import { database } from "@lib/database";

const { data } = await database
  .from("APODs")
  .select("date")
  .order("date", { ascending: false })
  .limit(1);

const navList = [
  ["APOD", "/apod", "Astronomy Picture of the Day"],
  ["Archive", "/archive", "Collection of thousands on APODs"],
  ["Gallery", "/gallery", "Capture the cosmos in its fullest quality",],
  ["Random", "/random", "Get a random Astronomy Picture"],
]

const lastDate = data?.[0].date;
const latestApod = await fetch(
  "https://api.nasa.gov/planetary/apod?api_key=DEMO_KEY",
).then((r) => r.json());
const latestDate: string = latestApod.date;
---

<header class="fixed top-0 w-screen z-50 flex justify-center pt-6 px-4 bg-linear-to-b from-black to-transparent">
  <nav class="flex h-14 w-full max-w-5xl px-3 items-center justify-between rounded-3xl border border-white/10 bg-black/40 backdrop-blur-xl transition-all duration-500 hover:border-white/20 hover:bg-black/60 shadow-[0_20px_50px_rgba(0,0,0,0.3)]" aria-label="Primary navigation" >
      <a href="/" title="Home - astroDaily" class="group flex items-center gap-3" aria-label="astroDaily homepage">
        <img src="/star.svg" alt="astroDaily logo" class="object-contain h-8 w-8 transition-transform duration-500 group-hover:rotate-360 group-hover:scale-110" />
        <span class="hidden md:block font-sans text-xs font-bold uppercase tracking-[0.3em] text-white/90">
          astroDaily
        </span>
      </a>

      <ul class="flex items-center gap-6">
        {navList.map(([label, href, title]) => {
            const isActive = Astro.url.pathname === href;
            return (
            <li class="relative group">
              <a href={href} aria-current={isActive ? "page" : undefined} title={title} class={`font-sans text-[11px] font-bold uppercase tracking-widest transition-colors duration-300 ${isActive ? "text-white" : "text-zinc-400 group-hover:text-white"}`}>
                {label}
              </a>
              <span class={`absolute left-0 h-px bg-zinc-500 transition-all duration-300 ${isActive ? "w-full" : "w-0 group-hover:w-full"}`} />
            </li>
            );
        })}
      </ul>

      <span class="hidden md:inline-block text-[10px] font-mono text-zinc-400/80 bg-zinc-500/10 px-2 py-1 rounded-4xl border border-zinc-500/20">
        {lastDate === latestDate ? "LIVE_DATA" : "OLD_DATA"}
      </span>

  </nav>
</header>
