---
import { Image } from "astro:assets";
import { database } from "@lib/database";
import Icon from "./icons.astro";

const { data: galleryItems } = await database
  .from("APODs")
  .select("date, title, url, hdurl")
  .order("date", { ascending: false })
  .limit(12);
---

<section id="gallery-preview" aria-labelledby="gallery-heading" class="w-full px-6 py-24 md:py-32 hidden md:block" >
  <div class="mx-auto flex max-w-6xl flex-col gap-16">
    <header class="text-center">
      <h2 id="gallery-heading" class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-zinc-100">
        Gallery
      </h2>
    </header>

    <div class="columns-1 md:columns-2 lg:columns-3 xl:columns-4 gap-8 space-y-8">
      {galleryItems?.map((item) => (
        <article class="break-inside-avoid">
          <figure class="group relative overflow-hidden rounded-3xl bg-white/5 transition-all duration-500 hover:bg-white/10" >
            <Image src={item.url || ""} width={800} height={1000} alt={item.title} loading="lazy" class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
            <figcaption class="absolute inset-0 flex items-end bg-linear-to-t from-black/80 via-black/30 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" >
              <div class="p-4 flex flex-col gap-1 translate-y-4 transition-transform duration-500 group-hover:translate-y-0">
                <span class="text-xs font-semibold uppercase tracking-[0.3em] text-white/70">
                  {item.date}
                </span>
                <h3 class="text-white text-lg font-medium leading-tight line-clamp-1">
                  {item.title}
                </h3>
              </div>
            </figcaption>
          </figure>
        </article>
      ))}
    </div>

    <div class="flex justify-center">
      <a href="/gallery" class="group flex items-center justify-center gap-2 rounded-3xl bg-white px-8 py-4 text-sm font-semibold text-black transition-transform active:scale-95 hover:bg-zinc-200" >
        Browse Full Archive
        <Icon glyph="arrow-right" class="group-hover:translate-x-1 transition-transform duration-300"/>
      </a>
    </div>
  </div>
</section>