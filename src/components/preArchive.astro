---
import { database } from "@lib/database";
import Icon from "./icons.astro";

const { data: recent } = await database
  .from("APODs")
  .select("date, title, url, hdurl, media_type, explanation, copyright")
  .order("date", { ascending: false })
  .limit(5);

const { count: totalCount } = await database
  .from("APODs")
  .select("*", { count: "exact", head: true });

const currentYear  = new Date().getFullYear();
const currentMonth  = new Date().getMonth();
const yearsOfData  = currentYear - 1995 + 1;

function thumb(url: string | null | undefined, w = 600, q = 100, b = 0) {
  if (!url) return "";
  return `https://wsrv.nl/?url=${encodeURIComponent(url)}&w=${w}&output=webp&q=${q}&blur=${b}`;
}

const [featured, ...sidebar] = recent ?? [];
---

<section class="relative w-full py-28 px-6 overflow-hidden">
  <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-64 bg-zinc-400/5 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto">
    <header class="flex items-end justify-between mb-14 gap-6 flex-wrap">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-zinc-500">
          NASA • since 1955
        </p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-zinc-100 leading-tight">
          Explore the Archive
        </h2>
      </div>

      <div class="flex items-center gap-6 md:gap-10 shrink-0">
        <div class="flex flex-col gap-1 items-center justify-center">
          <p class="font-mono text-2xl md:text-3xl font-bold text-white tabular-nums leading-none">
            {totalCount?.toLocaleString() ?? "10,000+"}
          </p>
          <p class="font-semibold text-[10px] tracking-[0.3em] uppercase text-zinc-700 mt-1">
            Pictures
          </p>
        </div>
        <div class="w-px h-10 bg-white/8"></div>
        <div class="flex flex-col gap-1 items-center justify-center">
          <p class="font-mono text-2xl md:text-3xl font-bold text-white tabular-nums leading-none">
            {yearsOfData}
          </p>
          <p class="font-semibold text-[10px] tracking-[0.3em] uppercase text-zinc-700">
            Years
          </p>
        </div>
      </div>
    </header>

    {featured && (
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-5 mb-5">
        <a href={`/apod`} class="group relative rounded-2xl md:rounded-3xl overflow-hidden border border-white/3 bg-zinc-900/40 min-h-105 md:min-h-130 flex flex-col justify-end hover:border-white/6 transition-all duration-500" >
          {featured.url && (
            <div class="absolute inset-0">
              <img src={thumb(featured.hdurl ?? featured.url, 1200)} alt={featured.title ?? ""} class="w-full h-full object-cover opacity-60 group-hover:opacity-75 group-hover:scale-[1.02] transition-all duration-700 ease-out" loading="lazy" />
            </div>
          )}

          <div class="absolute inset-0 bg-linear-to-t from-black via-[#07090f]/60 to-transparent"></div>

          <div class="relative z-10 p-7 md:p-10">
            <h3 class="text-2xl md:text-4xl text-white font-bold leading-tight tracking-tight mb-4 max-w-2xl group-hover:text-zinc-100 transition-colors duration-300">
              {featured.title}
            </h3>

            <p class="text-zinc-500 leading-relaxed text-balance max-w-xl line-clamp-2 mb-6 group-hover:text-zinc-400 transition-colors duration-300">
              {featured.explanation}
            </p>

            <span class="inline-flex items-center gap-2.5 text-[11px] tracking-widest uppercase text-zinc-500 group-hover:text-zinc-200 transition-colors duration-300">
              View picture
              <Icon glyph="arrow-right" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform duration-300" />
            </span>
          </div>

          <div class="absolute top-5 left-5 z-10">
            <span class="flex items-center gap-2 bg-black/50 backdrop-blur-md border border-white/8 rounded-full px-3 py-1.5">
              <span class="relative flex h-1.5 w-1.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-400 opacity-50"></span>
                <span class="relative rounded-full h-1.5 w-1.5 bg-zinc-400/70"></span>
              </span>
              <span class="font-mono text-[10px] tracking-[0.18em] uppercase text-zinc-400">Latest</span>
            </span>
          </div>
        </a>

        <div class="flex flex-col gap-5">
          {sidebar.slice(0, 4).map((apod, i) => (
            <a href={`/archive/${apod.date}`} class="group relative flex items-stretch gap-0 rounded-3xl overflow-hidden border border-white/10 bg-white/3 hover:bg-white/6 hover:border-white/20 transition-all duration-300 flex-1 min-h-0" style={`animation-delay: ${i * 60}ms`} >
              <div class="relative w-24 shrink-0 overflow-hidden">
                {apod.url && (
                  <img src={thumb(apod.url, 20, 1, 3)} data-src={thumb(apod.url, 400, 80)} alt="" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-500 scale-110 bg-white/10 animate-pulse ease-in-out" loading="lazy"
                    onload="if (this.dataset.src && this.src !== this.dataset.src) {
                      const full = new Image();
                      full.onload = () => { this.src = this.dataset.src; this.classList.remove('blur-xl', 'scale-110', 'animate-pulse'); };
                      full.src = this.dataset.src;
                    }"
                  />
                )}
                <div class="absolute inset-0 bg-linear-to-r from-transparent to-zinc-900/60"></div>
              </div>

              <div class="flex flex-col justify-center px-4 py-3 flex-1 min-w-0">
                <p class="font-mono text-[9px] tracking-[0.2em] uppercase text-zinc-500 mb-1.5">
                  {apod.date}
                </p>
                <p class="text-md text-zinc-300 font-bold leading-snug line-clamp-2 group-hover:text-white transition-colors duration-200">
                  {apod.title}
                </p>
              </div>

              <div class="flex items-center pr-4 shrink-0">
                <Icon glyph="chevron-right" class="w-3 h-3 transition-transform duration-200 ease-out scale-0 group-hover:scale-105 -translate-x-3 group-hover:translate-x-0"/>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="relative rounded-3xl border border-white/5 bg-zinc-900/20 px-6 py-5 overflow-hidden">
      <p class="flex flex-row items-center text-[11px] tracking-[0.3em] uppercase text-zinc-800 mb-4">
        Jump to
        <span class="ml-5 flex-1 h-px bg-white/5"></span>
      </p>

      <div class="flex items-center gap-3 flex-wrap">
        {[currentYear, `${currentYear}/${currentMonth}`, 1995].map((yr) => (
          <a href={`/archive/${yr}`} class="group flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 hover:border-white/20 hover:bg-white/6 transition-all duration-200" >
            <span class="font-mono text-xs text-zinc-600 group-hover:text-zinc-200 transition-colors duration-200 tracking-wide">
              {yr === 1995 ? "1995 — First" : `${yr}`}
            </span>
          </a>
        ))}

        <span class="flex-1"></span>

        <a href="/archive/search" class="flex gap-2 group items-center rounded-3xl bg-white px-6 py-2.5 text-xs font-semibold text-black transition-transform active:scale-95 hover:bg-zinc-200" >
          Search Archive
          <Icon glyph="magnifying-glass" class="h-full w-auto group-hover:scale-110 transition-transform duration-300"/>
        </a>

        <a href="/archive" class="flex gap-2 group items-center text-xs font-semibold text-zinc-400 hover:text-zinc-200 transition-colors duration-300" >
          Browse full archive
          <Icon glyph="arrow-right" class="h-full w-auto group-hover:translate-x-1 transition-transform duration-300"/>
        </a>
      </div>
    </div>

  </div>
</section>
