---
import Layout from "@layouts/base.astro";
import Icon from "@components/icons.astro";
---

<Layout title="Archive | astroDaily">
  <section class="relative min-h-[calc(100dvh-12rem)] pt-28 px-4 md:px-8 max-w-7xl mx-auto">
    <header class="mb-20 text-center">
      <h1 class="font-bold text-8xl md:text-[12rem] tracking-tighter absolute left-1/2 -translate-x-1/2 top-0 select-none text-center bg-linear-0 from-black to-zinc-500 text-transparent bg-clip-text duration-700 hover:to-zinc-200 transition-colors whitespace-nowrap pointer-events-none" >
        Archive
      </h1>
      <h2 class="relative text-4xl md:text-6xl text-shadow-black font-bold text-zinc-100 tracking-tight" >
        Every cosmos catalouged
      </h2>
      <h3 class="text-zinc-400 relative text-[12px] md:text-[14px] text-shadow-black font-bold tracking-widest uppercase mt-2" >
        Full-text search across the entire APOD collection.
      </h3>
    </header>

    <div class="relative z-10 max-w-2xl mx-auto mb-10">
      <div class="relative group">
        <div class="absolute -inset-px rounded-2xl bg-linear-to-r from-zinc-700 via-zinc-500 to-zinc-700 opacity-0 transition-opacity duration-500 group-focus-within:opacity-100 blur-sm pointer-events-none"></div>

        <span class="absolute left-5 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500 pointer-events-none z-10 transition-colors duration-300 group-focus-within:text-zinc-300">
          <Icon glyph="magnifying-glass" />
        </span>

        <input id="search-input" type="search" placeholder="nebula, aurora, black hole…" autocomplete="off" class="relative w-full bg-zinc-900/80 border border-white/8 rounded-2xl pl-12 pr-12 py-4 text-zinc-200 placeholder-zinc-600 text-base tracking-wide focus:outline-none focus:border-zinc-600 transition-colors duration-300 backdrop-blur-sm" />
        <Icon glyph="loader-circle" id="search-spinner" class="hidden absolute right-5 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500 animate-spin"/>
      </div>
      <p id="result-meta" class="mt-3 h-4 text-center text-xs tracking-widest uppercase text-zinc-600 opacity-0 transition-opacity duration-300"></p>
    </div>
    
    <div class="relative z-10">
      <div id="browse-prompt" class="flex flex-col items-center justify-center pt-15 gap-4">
        <div class="flex gap-2 items-center opacity-30">
          <span class="block w-8 h-px bg-zinc-500"></span>
          <svg class="w-5 h-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.07-.7.7M5.63 18.37l-.7.7m12.73 0-.7-.7M5.63 5.63l-.7-.7"/>
          </svg>
          <span class="block w-8 h-px bg-zinc-500"></span>
        </div>
        <p class="text-sm tracking-widest uppercase text-zinc-600">Type to search the cosmos</p>
      </div>

      <div id="empty-state" class="hidden items-center justify-center py-20 border border-dashed border-white/10 rounded-3xl" >
        <p class="text-sm tracking-widest uppercase text-zinc-600">
          No cosmic data found for this query
        </p>
      </div>

      <div id="results-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10 place-items-center"></div>

      <div id="pagination" class="hidden justify-center">
        <button id="load-more-btn" class="relative px-8 py-3 mt-10 rounded-3xl text-black bg-white text-sm tracking-widest transition-all duration-300 flex items-center gap-3" >
            <Icon glyph="chevron-down" />
          <span id="load-more-label">Load more</span>
          <Icon glyph="loader-circle" id="load-more-spinner" class="hidden w-3 h-3 text-zinc-500 animate-spin"/>
        </button>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('astro:page-load', () =>{
    const LIMIT = 18
    let currentQuery = ""
    let currentPage  = 0
    let totalCount   = 0
    let isFetching   = false

    const input = document.getElementById("search-input") as HTMLInputElement
    const spinner = document.getElementById("search-spinner") as HTMLElement
    const metaEl = document.getElementById("result-meta") as HTMLElement
    const browsePrompt = document.getElementById("browse-prompt") as HTMLElement
    const emptyState = document.getElementById("empty-state") as HTMLElement
    const grid = document.getElementById("results-grid") as HTMLElement
    const pagination = document.getElementById("pagination") as HTMLElement
    const loadMoreBtn = document.getElementById("load-more-btn") as HTMLElement
    const loadMoreSpinner = document.getElementById("load-more-spinner") as HTMLElement
    const loadMoreLabel = document.getElementById("load-more-label") as HTMLElement

    async function fetchCards(q: string, page: number, append = false) {
      if (isFetching) return
      isFetching = true

      if (append) {
        loadMoreSpinner.classList.remove("hidden")
        loadMoreLabel.textContent = "Loading…"
      } else {
        spinner.classList.remove("hidden")
      }

      try {
        const params = new URLSearchParams({ q, limit: String(LIMIT), page: String(page) })
        const res = await fetch(`/api/search?${params}`)
        const json = await res.json()

        if (!res.ok) throw new Error(json.error ?? "Search failed")

        totalCount = json.count ?? 0

        if (!append) {
          grid.innerHTML = ""
          currentPage    = 0
        }

        injectCards(json.html ?? "", append)
        setMeta(q, totalCount)
        syncPagination()

      } catch (err) {
        console.error(err)
        setEmpty(true)
      } finally {
        isFetching = false
        spinner.classList.add("hidden")
        loadMoreSpinner.classList.add("hidden")
        loadMoreLabel.textContent = "Load more"
      }
    }

    function injectCards(html: string, append: boolean) {
      browsePrompt.classList.add("hidden")

      if (!html && !append) {
        setEmpty(true)
        return
      }

      setEmpty(false)

      const template = document.createElement("template")
      template.innerHTML = html
      const newCards = Array.from(template.content.children) as HTMLElement[]

      newCards.forEach((card, i) => {
        card.classList.add("search-card-enter")
        grid.appendChild(card)
        const delay = (i % LIMIT) * 40
        setTimeout(() => card.classList.add("search-card-visible"), delay)
      })
    }

    function setMeta(q: string, count: number) {
      metaEl.textContent = `${count.toLocaleString()} result${count !== 1 ? "s" : ""} for "${q}"`
      metaEl.classList.remove("opacity-0")
      metaEl.classList.add("opacity-100")
    }

    function syncPagination() {
      const shown = (currentPage + 1) * LIMIT
      if (shown < totalCount) {
        pagination.classList.remove("hidden")
        pagination.classList.add("flex")
      } else {
        pagination.classList.add("hidden")
        pagination.classList.remove("flex")
      }
    }

    function setEmpty(empty: boolean) {
      emptyState.classList.toggle("hidden", !empty)
      emptyState.classList.toggle("flex", empty)
      grid.classList.toggle("hidden", empty)
    }

    function reset() {
      currentQuery = ""
      grid.innerHTML = ""
      browsePrompt.classList.remove("hidden")
      emptyState.classList.add("hidden")
      emptyState.classList.remove("flex")
      grid.classList.remove("hidden")
      pagination.classList.add("hidden")
      pagination.classList.remove("flex")
      metaEl.textContent = ""
      metaEl.classList.add("opacity-0")
    }

    let timer: ReturnType<typeof setTimeout>
    input.addEventListener("input", () => {
      const q = input.value.trim()
      clearTimeout(timer)
      if (!q) { reset(); return }
      timer = setTimeout(() => {
        if (q === currentQuery) return
        currentQuery = q
        currentPage  = 0
        fetchCards(q, 0, false)
      }, 380)
    })

    loadMoreBtn.addEventListener("click", () => {
      if (isFetching || !currentQuery) return
      currentPage++
      fetchCards(currentQuery, currentPage, true)
    })
  });
</script>
