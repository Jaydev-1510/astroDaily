---
import { database } from "@lib/database";
import ApodCard from "@components/preApodCard.astro";
import Layout from "@layouts/base.astro";

const { year } = Astro.params;

if (!year) {
  return Astro.redirect("/archive");
}

const startDate = `${year}-01-01`;
const endDate = `${year}-12-31`;

const { data: days, error } = await database
  .from("APODs")
  .select("date, title, url")
  .gte("date", startDate)
  .lte("date", endDate)
  .order("date", { ascending: true });

if (!days) {
  return Astro.redirect("/archive");
}

const groupedByMonth = days?.reduce(
  (acc, day) => {
    const monthNumber = day.date.split("-")[1];
    if (!acc[monthNumber]) acc[monthNumber] = [];
    acc[monthNumber].push(day);
    return acc;
  },
  {} as Record<string, typeof days>,
);

const getMonthName = (m: string) =>
  new Date(Number(year), Number(m) - 1).toLocaleString("default", {
    month: "long",
  });

const months = Object.keys(groupedByMonth || {}).sort();
---

<Layout title={`Archive ${year}`}>
  <main class="pt-32 px-6 max-w-7xl mx-auto">
    <header class="mb-20 text-center">
      <h1
        class="font-sans font-bold text-9xl md:text-[12rem] tracking-tighter absolute left-1/2 -translate-x-1/2 top-20 select-none text-center bg-linear-0 from-black to-zinc-500 text-transparent bg-clip-text duration-700 hover:to-zinc-300 transition-colors"
      >
        {year}
      </h1>
      <h2
        class="relative text-4xl md:text-6xl text-shadow-black font-bold text-zinc-100 tracking-tight mt-10 font-sans"
      >
        Yearly Archive
      </h2>
      <div class="h-1 w-12 bg-zinc-500 mx-auto mt-6 rounded-full"></div>
    </header>

    <nav
      class="grid bg-white/2 grid-cols-6 md:flex lg:flex justify-center gap-6 md:gap-10 lg:gap-10 mb-20 place-items-center border border-[#252525] rounded-3xl py-7 px-5"
    >
      {
        months.map((m) => (
          <div class="flex flex-row gap-1 justify-center items-center">
            <a
              href={`#${getMonthName(m)}`}
              class="text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-white transition-colors duration-300"
            >
              {getMonthName(m).slice(0, 3)}
            </a>
            <a
              href={`/archive/${year}/${m}`}
              class="text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-white transition-colors duration-300"
            >
              <svg
                data-testid="geist-icon"
                height="12"
                stroke-linejoin="round"
                style="color:currentColor"
                viewBox="0 0 16 16"
                width="12"
              >
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M13.5 10.25V13.25C13.5 13.3881 13.3881 13.5 13.25 13.5H2.75C2.61193 13.5 2.5 13.3881 2.5 13.25L2.5 2.75C2.5 2.61193 2.61193 2.5 2.75 2.5H5.75H6.5V1H5.75H2.75C1.7835 1 1 1.7835 1 2.75V13.25C1 14.2165 1.7835 15 2.75 15H13.25C14.2165 15 15 14.2165 15 13.25V10.25V9.5H13.5V10.25ZM9 1H9.75H14.2495C14.6637 1 14.9995 1.33579 14.9995 1.75V6.25V7H13.4995V6.25V3.56066L8.53033 8.52978L8 9.06011L6.93934 7.99945L7.46967 7.46912L12.4388 2.5H9.75H9V1Z"
                  fill="currentColor"
                />
              </svg>
            </a>
          </div>
        ))
      }
    </nav>

    <div class="space-y-32">
      {
        months.map((m) => (
          <section id={getMonthName(m)} class="scroll-mt-32">
            <div class="flex items-baseline gap-4 mb-10 border-b border-white/5 pb-4">
              <h3 class="text-3xl font-bold text-white tracking-tight">
                {getMonthName(m)}
              </h3>
              <span class="text-zinc-500 font-mono text-sm">
                {groupedByMonth[m].length} items
              </span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10 place-items-center">
              {groupedByMonth[m].map((item) => (
                <ApodCard Apod={item} />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </main>
</Layout>
