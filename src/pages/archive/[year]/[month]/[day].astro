---
import { database } from "@lib/database";
import Layout from "@layouts/base.astro";
import ApodCard from "@components/apodCard.astro";

export const prerender = false;
export const revalidate = 86400;

const { year, month, day } = Astro.params;
const formattedDate = `${year}-${month?.padStart(2, "0")}-${day?.padStart(2, "0")}`;
const { data, error } = await database
  .from("APODs")
  .select("*")
  .eq("date", formattedDate)
  .single();

if (error || !data) {
  return Astro.redirect("/404");
}

const ogUrl = `https://astro--daily.vercel.app/api/og/${formattedDate}`;

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=31536000, stale-while-revalidate",
);
---

<Layout title={`Archive - ${formattedDate.replace("-", "/")} | astroDaily`} ogImage={ogUrl} description={`${data.explanation?.slice(0, 150) ?? ""}...`} type="article" author={data.copyright}>
  <h1 class="font-sans font-bold text-8xl md:text-[12rem] tracking-tighter relative mt-20 select-none text-center bg-linear-0 from-black to-zinc-500 text-transparent bg-clip-text duration-700 hover:to-zinc-300 transition-colors">
    Archive
  </h1>
  <ApodCard Apod={data} />
</Layout>
