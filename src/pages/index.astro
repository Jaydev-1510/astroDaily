---
import Layout from "@layouts/base.astro";
import Hero from "@components/heroSection.astro";
import Featured from "@components/featuredSection.astro";
import Past from "@components/pastSection.astro";
import Gallery from "@components/preGallery.astro"

export const prerender = true;
export const revalidate = 86400;
---

<Layout title="astroDaily">

    <!-- Hero section -->
    <Hero />

    <!-- Today's Astronomy Picture -->
    <Featured />

    <!-- Pictures from past -->
    <Past />

    <!-- Gallery preview -->
    <Gallery />

</Layout>
