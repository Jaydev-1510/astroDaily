---
import Layout from "@layouts/base.astro";
import { database } from "@lib/database";
import { Image } from "astro:assets";

const { data: galleryItems } = await database
  .from("APODs")
  .select("date, title, url, hdurl")
  .order("date", { ascending: false })
  .limit(100);
---

<Layout title="Cosmic Gallery | astroDaily">
  <main class="pt-32 pb-20 px-4 md:px-8 max-w-400 mx-auto">
    <header class="mb-10 text-center">
      <h1
        class="font-sans font-bold text-9xl md:text-[12rem] tracking-tighter absolute left-1/2 -translate-x-1/2 top-20 select-none text-center bg-linear-0 from-black to-zinc-500 text-transparent bg-clip-text duration-700 hover:to-zinc-200 transition-colors"
      >
        Gallery
      </h1>
      <h2
        class="text-zinc-400 relative text-[12px] md:text-[14px] text-shadow-black font-bold tracking-widest uppercase md:mt-25 mt-15 font-sans"
      >
        Capture the cosmos in its fullest quality.
      </h2>
    </header>

    <div
      class="columns-1 md:columns-2 lg:columns-3 xl:columns-4 gap-6 space-y-6 px-10"
    >
      {
        galleryItems?.map((item) => (
          <div class="relative group break-inside-avoid rounded-3xl border border-white/10 bg-white/5 overflow-hidden transition-all duration-500 hover:border-white/20 hover:shadow-[0_0_80px_rgba(99,102,241,0.1)]">
            <div class="absolute inset-0 animate-shimmer z-0" />
            <Image
              src={item.url || ""}
              width={800}
              height={1000}
              alt={item.title}
              class="w-full h-auto object-cover transition-all duration-1000 ease-out group-hover:scale-105 opacity-0 z-10"
              onload="this.classList.remove('opacity-0')"
            />

            <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-2">
              <div class="flex flex-col gap-1 mb-4 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-75">
                <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-white">
                  {item.date}
                </span>
                <h3 class="text-white font-medium text-lg leading-tight line-clamp-1">
                  {item.title}
                </h3>
              </div>

              <a
                href={item.hdurl || item.url}
                download={item.title}
                target="_blank"
                class="flex items-center justify-center gap-2 w-full py-3 rounded-3xl text-white font-bold text-[11px] uppercase tracking-widest translate-y-4 group-hover:translate-y-0 delay-150 border border-white/10 bg-black/10 backdrop-blur-xl transition-all duration-500 hover:border-white/20 hover:bg-black/60 shadow-[0_20px_50px_rgba(0,0,0,0.3)]"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="white"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="7 10 12 15 17 10" />
                    <line x1="12" y1="15" x2="12" y2="3" />
                  </>
                </svg>
                Download
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </main>
</Layout>
