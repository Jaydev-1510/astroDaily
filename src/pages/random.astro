---
import ApodCard from "@components/preApodCard.astro";
import Layout from "@layouts/base.astro";
import { database } from "@lib/database";

export const prerender = false;
const start = new Date(1995, 6, 16);
const end = new Date();

const random = new Date(
  start.getTime() + Math.random() * (end.getTime() - start.getTime()),
)
  .toISOString()
  .split("T")[0];

const { data: apod, error } = await database
  .from("APODs")
  .select("*")
  .eq("date", random);
---

<Layout>
  <main class="h-screen py-30 w-full px-6">
    <div class="w-full flex items-baseline justify-center gap-4 mb-10 border-b border-white/5 pb-4">
      <h3 class="text-3xl md:text-4xl lg:text-5xl font-bold text-zinc-200 tracking-tight text-center w-full">
        Random Apod for you on {random}
      </h3>
    </div>
    <div class="flex flex-col items-center justify-center gap-10">
      <ApodCard Apod={apod?.[0]} />
      <a href="/random" class="w-9/10 max-w-125 min-w-80 md:min-w-90 relative group flex items-center justify-center gap-2 py-4 rounded-2xl bg-white text-black font-semibold text-sm transition-transform active:scale-95 hover:bg-zinc-200">
        Randomize
        <svg class="group-hover:rotate-180 transition-transform duration-200" data-testid="geist-icon" height="16" stroke-linejoin="round" style="color:currentColor" viewBox="0 0 16 16" width="16">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M8.00002 1.25C5.33749 1.25 3.02334 2.73677 1.84047 4.92183L1.48342 5.58138L2.80253 6.29548L3.15958 5.63592C4.09084 3.91566 5.90986 2.75 8.00002 2.75C10.4897 2.75 12.5941 4.40488 13.2713 6.67462H11.8243H11.0743V8.17462H11.8243H15.2489C15.6631 8.17462 15.9989 7.83883 15.9989 7.42462V4V3.25H14.4989V4V5.64468C13.4653 3.06882 10.9456 1.25 8.00002 1.25ZM1.50122 10.8555V12.5V13.25H0.0012207V12.5V9.07538C0.0012207 8.66117 0.337007 8.32538 0.751221 8.32538H4.17584H4.92584V9.82538H4.17584H2.72876C3.40596 12.0951 5.51032 13.75 8.00002 13.75C10.0799 13.75 11.8912 12.5958 12.8266 10.8895L13.1871 10.2318L14.5025 10.9529L14.142 11.6105C12.9539 13.7779 10.6494 15.25 8.00002 15.25C5.05453 15.25 2.53485 13.4313 1.50122 10.8555Z" fill="currentColor">
          </path>
        </svg>
      </a>
    </div>
  </main>
</Layout>
