---
import { database } from "@lib/database";
import Layout from "@layouts/base.astro";
import ApodCard from "@components/apodCard.astro";

export const prerender = false;
const { data, error } = await database
  .from("APODs")
  .select("*")
  .order("date", { ascending: false })
  .limit(1)
  .single();

if (error || !data) {
  return Astro.redirect("/404");
}

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=31536000, stale-while-revalidate",
);
const year = data.date.split("-")[0];
const month = data.date.split("-")[1];
const day = data.date.split("-")[2];
const ogImage = `https://astro--daily.vercel.app/og/${year}/${month}/${day}.png`;
---

<Layout title="APOD | astroDaily">
  <ApodCard Apod={data} isArchive={false}/>
</Layout>
